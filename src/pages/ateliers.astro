---
import { getNavHref } from '../utils/nav';
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;

const ateliers = [
  {
    title: 'Paint & Jam',
    tag: 'Créativité',
    description: 'Peinture intuitive sur fond de musique afro, soul et jazz. Pas besoin de savoir dessiner — juste l\'envie de lâcher prise et de créer dans une ambiance bienveillante.',
    details: ['2h30 d\'atelier', 'Matériel fourni', 'Musique live ou DJ set', 'Collation incluse'],
    accent: 'var(--color-accent)',
  },
  {
    title: 'Self-Care Rituals',
    tag: 'Bien-être',
    description: 'Un moment de douceur inspiré des traditions de soin afro-caribéennes. Masques naturels, huiles essentielles, méditation guidée et partage entre femmes.',
    details: ['2h d\'atelier', 'Produits naturels fournis', 'Méditation guidée', 'Tisane offerte'],
    accent: 'var(--color-coral)',
  },
  {
    title: 'Atelier sur mesure',
    tag: 'Événements',
    description: 'Anniversaires, EVJF, team building ou événements privés. Créez une expérience Masoda à votre image, avec une formule entièrement personnalisée.',
    details: ['Durée flexible', 'Formule personnalisée', 'Groupe de 6 à 25 personnes', 'Devis sur demande'],
    accent: 'var(--color-brand)',
  },
];
---

<BaseLayout title="Nos Ateliers — Les Ateliers Masoda" description="Découvrez nos ateliers créatifs et bien-être. Peinture, rituels de soin, événements sur mesure. Réservez votre place.">

  <!-- Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="page-hero__content reveal">
        <span class="overline">Ateliers</span>
        <h1 class="heading-1">Créer, partager, se ressourcer.</h1>
        <p class="subtitle">Des ateliers pensés pour se reconnecter à soi à travers la créativité et le bien-être.</p>
        <a href="https://www.billetweb.fr/paint-and-jam-with-love" target="_blank" rel="noopener" class="btn btn--primary">
          Réserver maintenant
        </a>
      </div>
    </div>
  </section>

  <!-- Ateliers list -->
  <section class="section">
    <div class="container">
      {ateliers.map((atelier, i) => (
        <article class={`atelier-card reveal ${i % 2 === 1 ? 'atelier-card--reverse' : ''}`}>
          <div class="atelier-card__visual">
            <div class="atelier-card__image" style={`background: linear-gradient(135deg, ${atelier.accent}18, ${atelier.accent}06);`}>
              <span class="atelier-card__icon" style={`color: ${atelier.accent};`}>✦</span>
            </div>
          </div>
          <div class="atelier-card__content">
            <span class="overline" style={`color: ${atelier.accent};`}>{atelier.tag}</span>
            <h2 class="heading-3">{atelier.title}</h2>
            <p class="atelier-card__desc">{atelier.description}</p>
            <ul class="atelier-card__details">
              {atelier.details.map(d => (
                <li>{d}</li>
              ))}
            </ul>
            <a href="https://www.billetweb.fr/paint-and-jam-with-love" target="_blank" rel="noopener" class="btn btn--primary">
              Réserver
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- FAQ -->
  <section class="section faq-section">
    <div class="container container--narrow">
      <div class="reveal">
        <h2 class="heading-3 faq-section__title">Questions fréquentes</h2>
        <div class="faq-list">
          <details class="faq-item">
            <summary>Faut-il avoir de l'expérience en peinture ?</summary>
            <p>Pas du tout ! Nos ateliers sont pensés pour tous les niveaux. L'important, c'est de passer un bon moment.</p>
          </details>
          <details class="faq-item">
            <summary>Que dois-je apporter ?</summary>
            <p>Rien de spécial. Tout le matériel est fourni. Venez simplement avec des vêtements que vous n'avez pas peur de tacher.</p>
          </details>
          <details class="faq-item">
            <summary>Peut-on venir entre amies ?</summary>
            <p>Absolument ! C'est même encouragé. Vous pouvez aussi offrir un atelier en cadeau.</p>
          </details>
          <details class="faq-item">
            <summary>Comment se passe l'inscription ?</summary>
            <p>Les réservations se font via notre plateforme en ligne. Vous recevrez un e-mail de confirmation avec tous les détails pratiques.</p>
          </details>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding-block: var(--space-16) var(--space-12);
    background: var(--color-bg);
  }

  .page-hero__content {
    max-width: 650px;
  }

  .page-hero__content .overline {
    display: block;
    margin-bottom: var(--space-3);
  }

  .page-hero__content h1 {
    margin-bottom: var(--space-4);
  }

  .page-hero__content .subtitle {
    margin-bottom: var(--space-8);
  }

  .atelier-card {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    align-items: center;
    padding-block: var(--space-10);
    border-bottom: 1px solid var(--color-border);
  }

  .atelier-card:last-child {
    border-bottom: none;
  }

  .atelier-card__visual {
    display: flex;
    justify-content: center;
  }

  .atelier-card__image {
    width: 100%;
    max-width: 420px;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-xl);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-border);
  }

  .atelier-card__icon {
    font-size: var(--text-5xl);
    opacity: 0.4;
  }

  .atelier-card__content .overline {
    display: block;
    margin-bottom: var(--space-2);
  }

  .atelier-card__content h2 {
    margin-bottom: var(--space-4);
  }

  .atelier-card__desc {
    color: var(--color-text-light);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-6);
  }

  .atelier-card__details {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2) var(--space-4);
    margin-bottom: var(--space-8);
  }

  .atelier-card__details li {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    padding-left: var(--space-4);
    position: relative;
  }

  .atelier-card__details li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: var(--weight-bold);
  }

  /* FAQ */
  .faq-section {
    background: var(--color-bg-light);
  }

  .faq-section__title {
    margin-bottom: var(--space-8);
  }

  .faq-item {
    border-bottom: 1px solid var(--color-border);
    padding-block: var(--space-5);
  }

  .faq-item summary {
    font-weight: var(--weight-semibold);
    cursor: pointer;
    font-size: var(--text-base);
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .faq-item summary::after {
    content: '+';
    font-size: var(--text-xl);
    color: var(--color-accent);
    transition: transform var(--duration-fast);
  }

  .faq-item[open] summary::after {
    transform: rotate(45deg);
  }

  .faq-item p {
    margin-top: var(--space-3);
    color: var(--color-text-light);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    padding-right: var(--space-8);
  }

  @media (min-width: 768px) {
    .page-hero {
      padding-block: var(--space-24) var(--space-16);
    }

    .atelier-card {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-12);
      padding-block: var(--space-16);
    }

    .atelier-card--reverse .atelier-card__visual {
      order: 2;
    }
  }
</style>
