import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/home/HeroSection.astro';
import AteliersSection from '../components/home/AteliersSection.astro';
import WellbeingSection from '../components/home/WellbeingSection.astro';
import CredibilitySection from '../components/home/CredibilitySection.astro';
import JournalSection from '../components/home/JournalSection.astro';
