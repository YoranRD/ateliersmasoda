---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
const basePath = base.endsWith('/') ? base : `${base}/`;

const articles = [
  {
    tag: 'Bien-être',
    title: '5 rituels du matin pour commencer la journée en douceur',
    excerpt: 'Des gestes simples, inspirés des traditions afro-caribéennes, pour ancrer votre matinée dans la sérénité.',
    date: 'À paraître',
    image: `${basePath}images/home/bien-etre-lifestyle.png`,
    alt: 'Rituels bien-être Massoda',
  },
  {
    tag: 'Créativité',
    title: 'Oser créer sans jugement : le pouvoir de l\'art intuitif',
    excerpt: 'Pourquoi peindre sans règle peut transformer votre rapport à vous-même et libérer votre expression.',
    date: 'En écriture',
    image: `${basePath}images/home/atelier-paint-jam.png`,
    alt: 'Atelier Paint & Jam — peinture intuitive',
  },
  {
    tag: 'Plantes',
    title: 'Les plantes africaines anti-stress à redécouvrir',
    excerpt: 'Tisanes, racines et infusions : les trésors végétaux du continent et des îles, à intégrer au quotidien.',
    date: 'En préparation',
    image: `${basePath}images/shop/boutique-plantes.png`,
    alt: 'Plantes & infusions afro-diététique',
  },
  {
    tag: 'Artisanat',
    title: 'Baya : l\'histoire des perles de taille',
    excerpt: 'Symbole de féminité et d\'ancrage, la baya raconte un héritage transmis de femme à femme.',
    date: 'À paraître',
    image: `${basePath}images/home/atelier-baya.png`,
    alt: 'Baya — perles de taille traditionnelles',
  },
  {
    tag: 'Communauté',
    title: 'Pourquoi les cercles de femmes nous font tant de bien',
    excerpt: 'La force du collectif féminin : un espace de parole, d\'écoute et de soutien qui transforme.',
    date: 'En écriture',
    image: `${basePath}images/home/communaute-masoda.png`,
    alt: 'Communauté Massoda — moments de partage',
  },
  {
    tag: 'Identité',
    title: 'Massoda, une parole sincère sur le bien-être afro-caribéen',
    excerpt: 'Comment la fondatrice imagine un espace ancré, exigeant et profondément chaleureux.',
    date: 'En préparation',
    image: `${basePath}images/about/fondatrice-masoda.png`,
    alt: 'Fondatrice des Ateliers Massoda',
  },
];
---

<BaseLayout title="Journal — Les Ateliers Massoda" description="Inspirations, bien-être et culture afro-caribéenne. Articles et ressources pour prendre soin de soi autrement.">

  <section class="page-hero">
    <div class="container">
      <div class="page-hero__content reveal">
        <span class="overline">Journal</span>
        <h1 class="heading-1">Inspirations & ressources</h1>
        <p class="subtitle">Le journal Massoda se construit progressivement : voici les premiers sujets qui s'écrivent autour du bien-être, de la créativité et des cultures afro-caribéennes.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="journal-grid">
        {articles.map((article, i) => (
          <article class={`card reveal reveal-delay-${(i % 4) + 1}`}>
            <div class="journal-image-wrap">
              <img
                src={article.image}
                alt={article.alt}
                class="journal-image"
                loading="lazy"
                width="800"
                height="600"
              />
            </div>
            <div class="card__body">
              <div class="journal-meta">
                <span class="card__tag">{article.tag}</span>
                <span class="journal-date">{article.date}</span>
              </div>
              <h2 class="card__title">{article.title}</h2>
              <p class="card__text">{article.excerpt}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section journal-cta-section">
    <div class="container container--narrow">
      <div class="journal-cta reveal">
        <h2 class="heading-4">Le journal s'écrit en ce moment.</h2>
        <p>Les premiers articles arrivent par vagues. Suivez-nous sur Instagram pour être prévenue dès leur publication.</p>
        <a href="https://www.instagram.com/lesateliersmassoda/" target="_blank" rel="noopener" class="btn btn--primary">
          Suivre sur Instagram
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding-block: var(--space-16) var(--space-12);
    background: var(--color-bg);
  }

  .page-hero__content {
    max-width: 600px;
  }

  .page-hero__content .overline {
    display: block;
    margin-bottom: var(--space-3);
  }

  .page-hero__content h1 {
    margin-bottom: var(--space-4);
  }

  .journal-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  .journal-image-wrap {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-surface-warm);
  }

  .journal-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Cards are not yet clickable — keep them visually static. */
  .journal-grid .card {
    cursor: default;
  }

  .journal-grid .card:hover {
    transform: none;
    box-shadow: var(--shadow-sm);
  }

  .journal-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-2);
  }

  .journal-date {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .journal-cta-section {
    background: var(--color-bg-light);
  }

  .journal-cta {
    text-align: center;
  }

  .journal-cta h2 {
    margin-bottom: var(--space-4);
  }

  .journal-cta p {
    color: var(--color-text-light);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-8);
  }

  @media (min-width: 640px) {
    .journal-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 768px) {
    .page-hero {
      padding-block: var(--space-24) var(--space-16);
    }
  }

  @media (min-width: 1024px) {
    .journal-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
