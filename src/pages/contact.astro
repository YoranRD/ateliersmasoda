---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getNavHref } from '../utils/nav';

const base = import.meta.env.BASE_URL;
const legalHref = getNavHref('mentions-legales', base);
---

<BaseLayout title="Contact — Les Ateliers Massoda" description="Contactez Les Ateliers Massoda pour toute question, collaboration ou événement sur mesure.">

  <section class="page-hero">
    <div class="container">
      <div class="page-hero__content reveal">
        <span class="overline">Contact</span>
        <h1 class="heading-1">Parlons ensemble</h1>
        <p class="subtitle">Une question, une idée de collaboration, un atelier privé ou simplement envie d'échanger ? Nous lisons chaque message.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container contact-grid">
      <!-- Contact info -->
      <div class="contact-info reveal">
        <div class="contact-info__block">
          <h2 class="heading-4">Collaborations & lieux</h2>
          <p>Marques, créatrices, lieux d'accueil : si nos univers se rejoignent, construisons quelque chose ensemble. Nous sommes aussi ouvertes aux propositions de nouveaux lieux pour accueillir des formats spécifiques.</p>
        </div>

        <div class="contact-info__block">
          <h2 class="heading-4">Ateliers privés & sur mesure</h2>
          <p>Anniversaires, EVJF, team building, associations : nous concevons une expérience Massoda à l'image de votre groupe.</p>
        </div>

        <div class="contact-info__block">
          <h2 class="heading-4">Nous retrouver</h2>
          <ul class="contact-info__links">
            <li><a href="https://www.instagram.com/lesateliersmassoda/" target="_blank" rel="noopener">Instagram</a></li>
            <li><a href="https://www.tiktok.com/@lesateliersmassoda1" target="_blank" rel="noopener">TikTok</a></li>
            <li><a href="https://fr.pinterest.com/barbandchill/" target="_blank" rel="noopener">Pinterest</a></li>
          </ul>
          <p class="contact-info__email">
            Ou écrivez directement à <a href="mailto:yoranrd@gmail.com">yoranrd@gmail.com</a>
          </p>
        </div>
      </div>

      <div class="contact-form-wrap reveal reveal-delay-1">
        <form
          class="contact-form"
          id="contact-form"
          name="contact"
          action="https://api.web3forms.com/submit"
          method="POST"
        >
          <input type="hidden" name="access_key" value="519f48fd-824e-4443-81f1-f78653fbcfce" />
          <input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" class="contact-form__botcheck" />
          <div class="contact-form__group">
            <label for="name">Nom</label>
            <input type="text" id="name" name="name" placeholder="Votre nom" required />
          </div>
          <div class="contact-form__group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="votre@email.com" required />
          </div>
          <div class="contact-form__group">
            <label for="subject">Sujet</label>
            <select id="subject" name="subject" required>
              <option value="" disabled selected>Choisir un sujet</option>
              <option value="collaboration">Collaboration</option>
              <option value="evenement">Événement privé</option>
              <option value="presse">Presse</option>
              <option value="autre">Autre</option>
            </select>
          </div>
          <div class="contact-form__group">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="5" placeholder="Votre message..." required></textarea>
          </div>
          <button type="submit" class="btn btn--primary contact-form__submit">Envoyer</button>
          <p
            id="contact-form-status"
            class="contact-form__status"
            role="status"
            aria-live="polite"
            aria-atomic="true"
            hidden
          ></p>
          <p class="contact-form__privacy">
            Vos messages sont transmis via le service <a href="https://web3forms.com/" target="_blank" rel="noopener">Web3Forms</a>. Les informations envoyées servent uniquement à vous répondre. Plus de détails dans nos <a href={legalHref}>mentions légales</a>.
          </p>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form');
  const status = document.getElementById('contact-form-status');

  if (form instanceof HTMLFormElement && status instanceof HTMLParagraphElement) {
    const submitButton = form.querySelector('.contact-form__submit');
    const subjectField = form.querySelector('#subject');
    const initialButtonText =
      submitButton instanceof HTMLButtonElement ? submitButton.textContent : 'Envoyer';

    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      if (!(submitButton instanceof HTMLButtonElement)) {
        return;
      }

      const formData = new FormData(form);
      const subjectLabel =
        subjectField instanceof HTMLSelectElement
          ? subjectField.options[subjectField.selectedIndex]?.text || subjectField.value
          : 'Contact';
      const payload = Object.fromEntries(formData.entries());

      payload.subject = `Contact Les Ateliers Massoda — ${subjectLabel}`;
      payload.sujet_selectionne = subjectLabel;

      submitButton.disabled = true;
      submitButton.textContent = 'Envoi en cours...';
      status.hidden = false;
      status.dataset.state = 'pending';
      status.textContent = 'Envoi en cours...';

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Accept: 'application/json'
          },
          body: JSON.stringify(payload)
        });

        const result = await response.json();

        if (response.ok) {
          status.dataset.state = 'success';
          status.textContent =
            result.message || 'Merci, votre message est bien arrivé. Nous revenons vers vous très vite.';
          form.reset();
        } else {
          status.dataset.state = 'error';
          status.textContent =
            result.message || "L'envoi n'a pas pu aboutir. Merci de réessayer ou de nous écrire à yoranrd@gmail.com.";
        }
      } catch (error) {
        console.error(error);
        status.dataset.state = 'error';
        status.textContent =
          "Connexion interrompue. Merci de réessayer ou de nous écrire à yoranrd@gmail.com.";
      } finally {
        submitButton.disabled = false;
        submitButton.textContent = initialButtonText || 'Envoyer';
      }
    });
  }
</script>

<style>
  .page-hero {
    padding-block: var(--space-16) var(--space-12);
    background: var(--color-bg);
  }

  .page-hero__content {
    max-width: 600px;
  }

  .page-hero__content .overline {
    display: block;
    margin-bottom: var(--space-3);
  }

  .page-hero__content h1 {
    margin-bottom: var(--space-4);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .contact-info__block h2 {
    margin-bottom: var(--space-3);
  }

  .contact-info__block p {
    color: var(--color-text-light);
    line-height: var(--leading-relaxed);
    font-size: var(--text-sm);
  }

  .contact-info__links {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .contact-info__links a {
    font-size: var(--text-sm);
    color: var(--color-accent);
    font-weight: var(--weight-medium);
    transition: color var(--duration-fast);
  }

  .contact-info__links a:hover {
    color: var(--color-accent-hover);
  }

  .contact-info__email {
    margin-top: var(--space-4);
  }

  .contact-info__email a {
    color: var(--color-accent);
    font-weight: var(--weight-semibold);
  }

  .contact-form-wrap {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    border: 1px solid var(--color-border);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .contact-form__group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .contact-form__group label {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text);
  }

  .contact-form__group input,
  .contact-form__group select,
  .contact-form__group textarea {
    font-family: var(--font-body);
    font-size: var(--text-base);
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-white);
    color: var(--color-text);
    transition: border-color var(--duration-fast);
  }

  .contact-form__group input:focus,
  .contact-form__group select:focus,
  .contact-form__group textarea:focus {
    outline: none;
    border-color: var(--color-brand);
    box-shadow: 0 0 0 3px rgba(68, 82, 199, 0.1);
  }

  .contact-form__group textarea {
    resize: vertical;
    min-height: 120px;
  }

  .contact-form__botcheck {
    display: none;
  }

  .contact-form__submit {
    align-self: flex-start;
    margin-top: var(--space-2);
  }

  .contact-form__submit:disabled {
    opacity: 0.8;
    cursor: wait;
  }

  .contact-form__status {
    min-height: 1.5rem;
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
  }

  .contact-form__status[data-state='pending'] {
    color: var(--color-text-light);
  }

  .contact-form__status[data-state='success'] {
    color: var(--color-brand);
  }

  .contact-form__status[data-state='error'] {
    color: var(--color-warm);
  }

  .contact-form__privacy {
    margin-top: var(--space-2);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
  }

  .contact-form__privacy a {
    color: var(--color-accent);
    font-weight: var(--weight-medium);
  }

  .contact-form__privacy a:hover {
    color: var(--color-accent-hover);
  }

  @media (min-width: 768px) {
    .page-hero {
      padding-block: var(--space-24) var(--space-16);
    }

    .contact-grid {
      grid-template-columns: 1fr 1.2fr;
      gap: var(--space-16);
    }
  }
</style>
