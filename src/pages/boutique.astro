---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getNavHref } from '../utils/nav';

const base = import.meta.env.BASE_URL;
const basePath = base.endsWith('/') ? base : `${base}/`;

const categories = [
  {
    name: 'Baya',
    description: 'Perles de taille traditionnelles, portées pour la féminité, l\'ancrage et la confiance en soi.',
    image: `${basePath}images/shop/boutique-baya.png`,
    alt: 'Baya — perles de taille traditionnelles',
    icon: null,
    badge: 'Première vague',
  },
  {
    name: 'Plantes africaines',
    description: 'Plantes médicinales et infusions inspirées des traditions africaines et caribéennes.',
    image: `${basePath}images/shop/boutique-plantes.png`,
    alt: 'Plantes & infusions afro-diététique',
    icon: null,
    badge: 'Première vague',
  },
  {
    name: 'Nutrition anti-stress',
    description: 'Compléments naturels et superaliments pour apaiser le corps et l\'esprit.',
    image: null,
    icon: '◉',
    badge: 'En préparation',
  },
  {
    name: 'Déco',
    description: 'Objets décoratifs chaleureux, inspirés de l\'artisanat afro-caribéen.',
    image: null,
    icon: '✦',
    badge: 'En préparation',
  },
  {
    name: 'Art',
    description: 'Œuvres, prints et créations pour habiller votre intérieur avec sens.',
    image: null,
    icon: '✎',
    badge: 'En préparation',
  },
];
---

<BaseLayout title="Boutique — Les Ateliers Masoda" description="Découvrez notre sélection curatée d'objets de bien-être, déco et lifestyle afro-caribéen.">

  <section class="page-hero">
    <div class="container">
      <div class="page-hero__content reveal">
        <span class="overline">Boutique</span>
        <h1 class="heading-1">Une sélection en préparation</h1>
        <p class="subtitle">Voici un aperçu de la future boutique Masoda. Une sélection curatée d'objets de bien-être, d'artisanat et de lifestyle afro-caribéen, dévoilée par vagues.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="boutique-grid">
        {categories.map((cat, i) => (
          <article class={`boutique-card reveal reveal-delay-${(i % 4) + 1}`}>
            {cat.image ? (
              <div class="boutique-card__image-wrap">
                <img
                  src={cat.image}
                  alt={cat.alt}
                  class="boutique-card__image"
                  loading="lazy"
                  width="600"
                  height="450"
                />
              </div>
            ) : (
              <div class="boutique-card__icon-wrap">
                <span class="boutique-card__icon">{cat.icon}</span>
              </div>
            )}
            <h2 class="boutique-card__title">{cat.name}</h2>
            <p class="boutique-card__text">{cat.description}</p>
            <span class={`boutique-card__badge boutique-card__badge--${cat.image ? 'soon' : 'later'}`}>{cat.badge}</span>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section boutique-notice">
    <div class="container container--narrow">
      <div class="boutique-notice__inner reveal">
        <h2 class="heading-4">La boutique se construit, vague après vague.</h2>
        <p>Pour être informée du lancement de chaque catégorie, suivez-nous sur Instagram — ou écrivez-nous directement si vous avez un projet ou une question.</p>
        <div class="boutique-notice__actions">
          <a href="https://www.instagram.com/lesateliersmassoda/" target="_blank" rel="noopener" class="btn btn--primary">
            Suivre sur Instagram
          </a>
          <a href={getNavHref('contact', base)} class="btn btn--ghost">
            Nous écrire
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding-block: var(--space-16) var(--space-12);
    background: var(--color-bg);
  }

  .page-hero__content {
    max-width: 600px;
  }

  .page-hero__content .overline {
    display: block;
    margin-bottom: var(--space-3);
  }

  .page-hero__content h1 {
    margin-bottom: var(--space-4);
  }

  .boutique-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  .boutique-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    text-align: center;
    position: relative;
  }

  .boutique-card__image-wrap {
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-md);
    overflow: hidden;
    margin-bottom: var(--space-5);
    background: var(--color-surface-warm);
  }

  .boutique-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .boutique-card__icon-wrap {
    width: 64px;
    height: 64px;
    border-radius: var(--radius-md);
    background: rgba(255, 155, 84, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-inline: auto;
    margin-bottom: var(--space-5);
  }

  .boutique-card__icon {
    font-size: var(--text-2xl);
    color: var(--color-accent);
  }

  .boutique-card__title {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    margin-bottom: var(--space-3);
  }

  .boutique-card__text {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    line-height: var(--leading-normal);
    margin-bottom: var(--space-4);
  }

  .boutique-card__badge {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-muted);
    background: var(--color-bg);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
  }

  .boutique-card__badge--soon {
    color: var(--color-accent);
    background: rgba(255, 155, 84, 0.12);
  }

  .boutique-notice__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: var(--space-4) var(--space-6);
  }

  .boutique-notice {
    background: var(--color-bg-light);
  }

  .boutique-notice__inner {
    text-align: center;
  }

  .boutique-notice__inner h2 {
    margin-bottom: var(--space-4);
  }

  .boutique-notice__inner p {
    color: var(--color-text-light);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-8);
  }

  @media (min-width: 640px) {
    .boutique-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 768px) {
    .page-hero {
      padding-block: var(--space-24) var(--space-16);
    }
  }

  @media (min-width: 1024px) {
    .boutique-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
