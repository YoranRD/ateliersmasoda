---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Les Ateliers Massoda — Ateliers créatifs, bien-être et lifestyle afro-caribéen.',
  ogImage,
} = Astro.props;

const base = import.meta.env.BASE_URL;
// base may or may not have a trailing slash depending on Astro version — normalise once
const basePath = base.endsWith('/') ? base : `${base}/`;
const canonicalURL = Astro.url.href.replace(/\/?$/, '/');

const siteOrigin = Astro.site ? Astro.site.origin : 'https://yoranrd.github.io';
const ogImagePath = ogImage ?? `${basePath}brand/og-masoda.png`;
const absoluteOgImage = ogImagePath.startsWith('http')
  ? ogImagePath
  : `${siteOrigin}${ogImagePath}`;

const organizationJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Les Ateliers Massoda',
  url: `${siteOrigin}${basePath}`,
  logo: `${siteOrigin}${basePath}brand/logo_halo.png`,
  sameAs: [
    'https://www.instagram.com/lesateliersmassoda/',
    'https://www.tiktok.com/@lesateliersmassoda1',
    'https://fr.pinterest.com/barbandchill/',
  ],
};
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="canonical" href={canonicalURL} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content="Les Ateliers Massoda" />
  <meta property="og:locale" content="fr_FR" />
  <meta property="og:image" content={absoluteOgImage} />
  <meta property="og:image:alt" content="Les Ateliers Massoda — visuel de marque" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={absoluteOgImage} />
  <link rel="icon" type="image/svg+xml" href={`${basePath}favicon.svg`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <script type="application/ld+json" set:html={JSON.stringify(organizationJsonLd)} />

  {/*
    Analytics placeholder — intentionally disabled.
    To enable later, drop in a privacy-friendly provider snippet here.
    Recommended options: Plausible, Umami, or Cloudflare Web Analytics.
    Example (Plausible):
    <script defer data-domain="yoranrd.github.io/ateliersmassoda" src="https://plausible.io/js/script.js"></script>
  */}
</head>
<body>
  <Header />
  <main>
    <div class="page-accent-line" aria-hidden="true"></div>
    <slot />
  </main>
  <Footer />

  <script>
    const reveals = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

    reveals.forEach(el => observer.observe(el));
  </script>
</body>
</html>
