---
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <!-- Brand -->
      <div class="footer__brand">
        <span class="footer__logo">Masoda</span>
        <p class="footer__tagline">Ateliers créatifs, bien-être<br/>et lifestyle afro-caribéen.</p>
      </div>

      <!-- Navigation -->
      <div class="footer__col">
        <h4 class="footer__heading">Navigation</h4>
        <ul class="footer__links">
          <li><a href={base}>Accueil</a></li>
          <li><a href={`${base}ateliers/`}>Ateliers</a></li>
          <li><a href={`${base}boutique/`}>Boutique</a></li>
          <li><a href={`${base}journal/`}>Journal</a></li>
        </ul>
      </div>

      <!-- En savoir plus -->
      <div class="footer__col">
        <h4 class="footer__heading">En savoir plus</h4>
        <ul class="footer__links">
          <li><a href={`${base}a-propos/`}>À propos</a></li>
          <li><a href={`${base}contact/`}>Contact</a></li>
        </ul>
      </div>

      <!-- Réseaux -->
      <div class="footer__col">
        <h4 class="footer__heading">Suivez-nous</h4>
        <ul class="footer__links">
          <li><a href="https://www.instagram.com/lesateliersmassoda/" target="_blank" rel="noopener">Instagram</a></li>
          <li><a href="https://www.tiktok.com/@lesateliersmassoda1" target="_blank" rel="noopener">TikTok</a></li>
          <li><a href="https://fr.pinterest.com/barbandchill/" target="_blank" rel="noopener">Pinterest</a></li>
        </ul>
      </div>
    </div>

    <div class="footer__bottom">
      <p>&copy; {year} Les Ateliers Masoda. Tous droits réservés.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-dark);
    color: var(--color-text-on-dark);
    padding-block: var(--space-16) var(--space-8);
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
    margin-bottom: var(--space-12);
  }

  .footer__logo {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    color: var(--color-accent);
    display: block;
    margin-bottom: var(--space-3);
  }

  .footer__tagline {
    font-size: var(--text-sm);
    color: rgba(246, 239, 231, 0.65);
    line-height: var(--leading-normal);
  }

  .footer__heading {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: rgba(246, 239, 231, 0.5);
    margin-bottom: var(--space-4);
  }

  .footer__links {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer__links a {
    font-size: var(--text-sm);
    color: rgba(246, 239, 231, 0.8);
    transition: color var(--duration-fast);
  }

  .footer__links a:hover {
    color: var(--color-accent);
  }

  .footer__bottom {
    padding-top: var(--space-8);
    border-top: 1px solid rgba(246, 239, 231, 0.1);
  }

  .footer__bottom p {
    font-size: var(--text-xs);
    color: rgba(246, 239, 231, 0.4);
  }

  @media (min-width: 768px) {
    .footer__grid {
      grid-template-columns: 2fr 1fr 1fr 1fr;
    }
  }
</style>
