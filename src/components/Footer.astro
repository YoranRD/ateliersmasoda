---
import { getNavHref } from '../utils/nav';

const base = import.meta.env.BASE_URL;
const basePath = base.endsWith('/') ? base : `${base}/`;
const year = new Date().getFullYear();
const logoUrl = `${basePath}brand/logo_halo.png`;
---

<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <!-- Brand -->
      <div class="footer__brand">
        <div class="footer__brand-row">
          <img src={logoUrl} alt="Logo Les Ateliers Massoda" class="footer__logo-img" width="48" height="48" loading="lazy" />
          <span class="footer__logo">Massoda</span>
        </div>
        <p class="footer__tagline">Ateliers créatifs, bien-être<br/>et lifestyle afro-caribéen.</p>
      </div>

      <!-- Navigation -->
      <div class="footer__col">
        <h4 class="footer__heading">Navigation</h4>
        <ul class="footer__links">
          <li><a href={getNavHref('', base)}>Accueil</a></li>
          <li><a href={getNavHref('ateliers', base)}>Ateliers</a></li>
          <li><a href={getNavHref('boutique', base)}>Boutique</a></li>
          <li><a href={getNavHref('journal', base)}>Journal</a></li>
        </ul>
      </div>

      <!-- En savoir plus -->
      <div class="footer__col">
        <h4 class="footer__heading">En savoir plus</h4>
        <ul class="footer__links">
          <li><a href={getNavHref('a-propos', base)}>À propos</a></li>
          <li><a href={getNavHref('contact', base)}>Contact</a></li>
        </ul>
      </div>

      <!-- Réseaux -->
      <div class="footer__col">
        <h4 class="footer__heading">Suivez-nous</h4>
        <ul class="footer__links">
          <li><a href="https://www.instagram.com/lesateliersmassoda/" target="_blank" rel="noopener">Instagram</a></li>
          <li><a href="https://www.tiktok.com/@lesateliersmassoda1" target="_blank" rel="noopener">TikTok</a></li>
          <li><a href="https://fr.pinterest.com/barbandchill/" target="_blank" rel="noopener">Pinterest</a></li>
        </ul>
      </div>
    </div>

    <div class="footer__bottom">
      <p>&copy; {year} Les Ateliers Massoda. Tous droits réservés.</p>
      <ul class="footer__legal">
        <li><a href={getNavHref('mentions-legales', base)}>Mentions légales</a></li>
      </ul>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-dark);
    color: var(--color-text-on-dark);
    padding-block: var(--space-16) var(--space-8);
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
    margin-bottom: var(--space-12);
  }

  .footer__brand-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
  }

  .footer__logo-img {
    width: 48px;
    height: 48px;
    object-fit: contain;
  }

  .footer__logo {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    color: var(--color-accent);
  }

  .footer__tagline {
    font-size: var(--text-sm);
    color: rgba(246, 239, 231, 0.65);
    line-height: var(--leading-normal);
  }

  .footer__heading {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: rgba(246, 239, 231, 0.5);
    margin-bottom: var(--space-4);
  }

  .footer__links {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer__links a {
    font-size: var(--text-sm);
    color: rgba(246, 239, 231, 0.8);
    transition: color var(--duration-fast);
  }

  .footer__links a:hover {
    color: var(--color-accent);
  }

  .footer__bottom {
    padding-top: var(--space-8);
    border-top: 1px solid rgba(246, 239, 231, 0.1);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    align-items: flex-start;
  }

  .footer__bottom p {
    font-size: var(--text-xs);
    color: rgba(246, 239, 231, 0.4);
  }

  .footer__legal {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .footer__legal a {
    font-size: var(--text-xs);
    color: rgba(246, 239, 231, 0.55);
    transition: color var(--duration-fast);
  }

  .footer__legal a:hover {
    color: var(--color-accent);
  }

  @media (min-width: 640px) {
    .footer__bottom {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  @media (min-width: 768px) {
    .footer__grid {
      grid-template-columns: 2fr 1fr 1fr 1fr;
    }
  }
</style>
