---
const base = import.meta.env.BASE_URL;
const basePath = base.endsWith('/') ? base : `${base}/`;

const collaborators = [
  {
    name: 'Boya',
    role: 'Création de baya — perles & savoir-faire',
    image: `${basePath}images/collaborators/collaborateur-1.png`,
    alt: 'Boya — collaboratrice Massoda, création de baya',
  },
  {
    name: 'Paint & Jam',
    role: 'Peinture intuitive & musique vivante',
    image: `${basePath}images/collaborators/collaborateur-2.png`,
    alt: 'Paint & Jam — collaboration Massoda autour de la peinture en musique',
  },
  {
    name: 'Plantes africaines & thé',
    role: 'Afro-diététique & rituels infusés',
    image: `${basePath}images/collaborators/collaborateur-3.png`,
    alt: 'Plantes africaines & thé — collaboration Massoda autour du bien-être',
  },
];
---

<section class="credibility section">
  <div class="container">
    <div class="credibility__header reveal">
      <span class="overline">Collaborations</span>
      <h2 class="heading-3">Celles & ceux qui font Massoda</h2>
      <p class="subtitle">
        Trois univers complices et un lieu partenaire, choisis pour leur sensibilité et leur savoir-faire.
      </p>
    </div>

    <div class="credibility__collabs reveal reveal-delay-1">
      {collaborators.map(c => (
        <article class="collab-card">
          <div class="collab-card__image-wrap">
            <img
              src={c.image}
              alt={c.alt}
              class="collab-card__image"
              loading="lazy"
              width="600"
              height="600"
            />
          </div>
          <h3 class="collab-card__name">{c.name}</h3>
          <span class="collab-card__role">{c.role}</span>
        </article>
      ))}
    </div>

    <div class="credibility__venue reveal reveal-delay-2">
      <div class="venue-card">
        <div class="venue-card__image-wrap">
          <img
            src={`${basePath}images/collaborators/bmk_collaborator.png`}
            alt="BMK Folie-Bamako — lieu partenaire des Ateliers Massoda à Paris"
            class="venue-card__image"
            loading="lazy"
            width="900"
            height="600"
          />
        </div>
        <div class="venue-card__content">
          <span class="overline venue-card__overline">Lieu partenaire</span>
          <h3 class="venue-card__name">BMK Folie-Bamako</h3>
          <p class="venue-card__text">
            La plupart de nos ateliers se vivent en ce moment chez BMK Folie-Bamako, une table chaleureuse au cœur du 11ᵉ. Un lieu choisi pour son âme, sa cuisine et son ouverture aux cultures afro-caribéennes.
          </p>
          <p class="venue-card__address">40 Rue Jean-Pierre Timbaud, 75011 Paris</p>
          <div class="venue-card__links">
            <a href="https://www.bmkparis.com/bmk-folie-bamako" target="_blank" rel="noopener">Site BMK</a>
            <span aria-hidden="true">·</span>
            <a href="https://www.instagram.com/bmkparisbamako/" target="_blank" rel="noopener">Instagram</a>
          </div>
        </div>
      </div>
    </div>

    <div class="credibility__quote reveal reveal-delay-3">
      <blockquote>
        <p>« On vient pour l'atelier, on repart avec un peu plus de soi. »</p>
        <footer>
          <cite>— L'esprit Massoda</cite>
        </footer>
      </blockquote>
    </div>
  </div>
</section>

<style>
  .credibility {
    background: var(--color-bg-warm);
  }

  .credibility__header {
    text-align: center;
    max-width: 520px;
    margin-inline: auto;
    margin-bottom: var(--space-12);
  }

  .credibility__header .overline {
    display: block;
    margin-bottom: var(--space-3);
  }

  .credibility__header h2 {
    margin-bottom: var(--space-4);
  }

  .credibility__collabs {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    max-width: 920px;
    margin-inline: auto;
    margin-bottom: var(--space-12);
  }

  .collab-card {
    text-align: center;
  }

  .collab-card__image-wrap {
    width: 100%;
    aspect-ratio: 1 / 1;
    max-width: 260px;
    margin-inline: auto;
    border-radius: var(--radius-full);
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    margin-bottom: var(--space-4);
  }

  .collab-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .collab-card__name {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    color: var(--color-text);
    margin-bottom: var(--space-1);
  }

  .collab-card__role {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    letter-spacing: var(--tracking-wide);
  }

  .credibility__venue {
    max-width: 920px;
    margin-inline: auto;
    margin-bottom: var(--space-12);
  }

  .venue-card {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .venue-card__image-wrap {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-surface-warm);
  }

  .venue-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .venue-card__content {
    padding: var(--space-6) var(--space-6) var(--space-8);
  }

  .venue-card__overline {
    display: block;
    margin-bottom: var(--space-2);
    color: var(--color-accent);
  }

  .venue-card__name {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    color: var(--color-text);
    margin-bottom: var(--space-3);
  }

  .venue-card__text {
    color: var(--color-text-light);
    line-height: var(--leading-relaxed);
    font-size: var(--text-sm);
    margin-bottom: var(--space-3);
  }

  .venue-card__address {
    font-size: var(--text-sm);
    color: var(--color-text);
    font-weight: var(--weight-medium);
    margin-bottom: var(--space-4);
  }

  .venue-card__links {
    display: flex;
    gap: var(--space-3);
    align-items: center;
    font-size: var(--text-sm);
  }

  .venue-card__links a {
    color: var(--color-accent);
    font-weight: var(--weight-semibold);
    transition: color var(--duration-fast);
  }

  .venue-card__links a:hover {
    color: var(--color-accent-hover);
  }

  .venue-card__links span {
    color: var(--color-text-muted);
  }

  .credibility__quote {
    max-width: 600px;
    margin-inline: auto;
    text-align: center;
  }

  .credibility__quote blockquote p {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-xl), 3vw, var(--text-3xl));
    font-style: italic;
    line-height: var(--leading-snug);
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  .credibility__quote cite {
    font-family: var(--font-body);
    font-style: normal;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  @media (min-width: 768px) {
    .credibility__collabs {
      grid-template-columns: repeat(3, 1fr);
    }

    .venue-card {
      grid-template-columns: 1fr 1.2fr;
      align-items: stretch;
      gap: 0;
    }

    .venue-card__image-wrap {
      aspect-ratio: auto;
      height: 100%;
    }

    .venue-card__content {
      padding: var(--space-8) var(--space-8);
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
  }
</style>
