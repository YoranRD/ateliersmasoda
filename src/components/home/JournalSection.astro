---
import { getNavHref } from '../../utils/nav';

const base = import.meta.env.BASE_URL;
const basePath = base.endsWith('/') ? base : `${base}/`;

const articles = [
  {
    tag: 'Bien-être',
    title: '5 rituels du matin pour commencer la journée en douceur',
    excerpt: 'Des gestes simples, inspirés de traditions afro-caribéennes, pour ancrer votre matinée.',
    image: `${basePath}images/home/bien-etre-lifestyle.png`,
    alt: 'Rituels bien-être Masoda',
  },
  {
    tag: 'Créativité',
    title: 'Oser créer sans jugement : le pouvoir de l\'art intuitif',
    excerpt: 'Pourquoi peindre sans règle peut transformer votre rapport à vous-même.',
    image: `${basePath}images/home/atelier-paint-jam.png`,
    alt: 'Atelier Paint & Jam — peinture intuitive',
  },
  {
    tag: 'Plantes',
    title: 'Les plantes africaines anti-stress à redécouvrir',
    excerpt: 'Tisanes, racines et infusions : les trésors végétaux qui apaisent corps et esprit.',
    image: `${basePath}images/shop/boutique-plantes.png`,
    alt: 'Plantes africaines & infusions bien-être',
  },
];
---

<section class="journal-section section">
  <div class="container">
    <div class="journal-section__header reveal">
      <div class="journal-section__header-text">
        <span class="overline">Journal</span>
        <h2 class="heading-3">Inspirations & ressources</h2>
      </div>
      <a href={getNavHref('journal', base)} class="btn btn--ghost">Voir tous les articles</a>
    </div>

    <div class="journal-section__grid">
      {articles.map((article, i) => (
        <article class={`card reveal reveal-delay-${i + 1}`}>
          <div class="journal-section__image-wrap">
            <img
              src={article.image}
              alt={article.alt}
              class="journal-section__image"
              loading="lazy"
              width="800"
              height="600"
            />
          </div>
          <div class="card__body">
            <span class="card__tag">{article.tag}</span>
            <h3 class="card__title">{article.title}</h3>
            <p class="card__text">{article.excerpt}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .journal-section {
    background: var(--color-bg);
  }

  .journal-section__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-bottom: var(--space-10);
  }

  .journal-section__header .overline {
    display: block;
    margin-bottom: var(--space-2);
  }

  .journal-section__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  .journal-section__image-wrap {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-surface-warm);
  }

  .journal-section__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Cards are not yet clickable — keep them visually static. */
  .journal-section__grid .card {
    cursor: default;
  }

  .journal-section__grid .card:hover {
    transform: none;
    box-shadow: var(--shadow-sm);
  }

  @media (min-width: 640px) {
    .journal-section__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 768px) {
    .journal-section__header {
      flex-direction: row;
      align-items: flex-end;
      justify-content: space-between;
    }

    .journal-section__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
