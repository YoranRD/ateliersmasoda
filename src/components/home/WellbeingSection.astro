---
import { getNavHref } from '../../utils/nav';

const base = import.meta.env.BASE_URL;
---

<section class="wellbeing section">
  <div class="container wellbeing__inner">

    <div class="wellbeing__visual reveal">
      <div class="wellbeing__frame-wrapper">
        <div class="wellbeing__corner wellbeing__corner--tl"></div>
        <div class="wellbeing__corner wellbeing__corner--br"></div>
        <div class="wellbeing__image-frame">
          <div class="wellbeing__placeholder">
            <span class="wellbeing__icon">◯</span>
          </div>
        </div>
      </div>
      <div class="wellbeing__accent-dot"></div>
    </div>

    <div class="wellbeing__content reveal reveal-delay-1">
      <span class="overline">Bien-être &amp; Lifestyle</span>
      <h2 class="heading-2">Un espace dédié au bien-être, à la créativité et au partage.</h2>
      <p class="wellbeing__text">
        Masoda est née de l'envie de créer un lieu où l'on prend soin de soi autrement.
        À travers des ateliers créatifs, des rituels de bien-être et une communauté bienveillante,
        nous célébrons la culture afro-caribéenne dans ce qu'elle a de plus lumineux.
      </p>
      <ul class="wellbeing__list">
        <li>
          <strong>Créativité libérée</strong>
          <span>Pas besoin d'être artiste, juste d'avoir envie.</span>
        </li>
        <li>
          <strong>Bien-être authentique</strong>
          <span>Des pratiques ancrées, pas des tendances vides.</span>
        </li>
        <li>
          <strong>Communauté chaleureuse</strong>
          <span>On vient seule, on repart avec des liens.</span>
        </li>
      </ul>
      <a href={getNavHref('a-propos', base)} class="btn btn--ghost">En savoir plus sur Masoda</a>
    </div>

  </div>
</section>

<style>
  .wellbeing {
    background: var(--color-bg);
  }

  .wellbeing__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  /* Visual side */
  .wellbeing__visual {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .wellbeing__frame-wrapper {
    position: relative;
    width: 100%;
    max-width: 380px;
  }

  /* Corner marks matching hero style */
  .wellbeing__corner {
    position: absolute;
    width: 20px;
    height: 20px;
    z-index: 2;
    pointer-events: none;
  }

  .wellbeing__corner--tl {
    top: -6px;
    left: -6px;
    border-top: 2px solid var(--color-warm-light);
    border-left: 2px solid var(--color-warm-light);
  }

  .wellbeing__corner--br {
    bottom: -6px;
    right: -6px;
    border-bottom: 2px solid var(--color-warm-light);
    border-right: 2px solid var(--color-warm-light);
  }

  .wellbeing__image-frame {
    width: 100%;
    aspect-ratio: 3 / 4;
    border-radius: var(--radius-xl);
    background: linear-gradient(160deg, var(--color-surface-warm) 0%, var(--color-bg-warm) 60%, rgba(154, 94, 73, 0.06) 100%);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-md);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .wellbeing__placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .wellbeing__icon {
    font-size: var(--text-6xl);
    color: var(--color-warm);
    opacity: 0.25;
  }

  /* Decorative dot */
  .wellbeing__accent-dot {
    position: absolute;
    bottom: -20px;
    right: 8%;
    width: 88px;
    height: 88px;
    border-radius: 50%;
    background: var(--color-coral);
    opacity: 0.14;
  }

  /* Content side */
  .wellbeing__content .overline {
    display: block;
    margin-bottom: var(--space-3);
  }

  .wellbeing__content h2 {
    margin-bottom: var(--space-6);
  }

  .wellbeing__text {
    color: var(--color-text-light);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-8);
  }

  /* List */
  .wellbeing__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    margin-bottom: var(--space-8);
  }

  .wellbeing__list li {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding-left: var(--space-5);
    border-left: 3px solid var(--color-accent);
  }

  .wellbeing__list strong {
    font-weight: var(--weight-semibold);
    font-size: var(--text-base);
    color: var(--color-text);
  }

  .wellbeing__list span {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    line-height: var(--leading-normal);
  }

  @media (min-width: 768px) {
    .wellbeing__inner {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-16);
    }
  }
</style>
