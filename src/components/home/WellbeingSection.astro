---
import { getNavHref } from '../../utils/nav';

const base = import.meta.env.BASE_URL;
const basePath = base.endsWith('/') ? base : `${base}/`;
const wellbeingImage = `${basePath}images/home/bien-etre-lifestyle.png`;
---

<section class="wellbeing section">
  <div class="container wellbeing__inner">
    <div class="wellbeing__visual reveal">
      <div class="wellbeing__image-frame">
        <img
          src={wellbeingImage}
          alt="Univers bien-être & lifestyle Massoda"
          class="wellbeing__image"
          loading="lazy"
          width="800"
          height="1066"
        />
      </div>
      <div class="wellbeing__accent-dot"></div>
    </div>

    <div class="wellbeing__content reveal reveal-delay-1">
      <span class="overline">Bien-être & Lifestyle</span>
      <h2 class="heading-3">Un espace dédié au bien-être, à la créativité et au partage.</h2>
      <p class="wellbeing__text">
        Massoda est née de l'envie de créer un lieu où l'on prend soin de soi autrement.
        À travers des ateliers créatifs, des rituels de bien-être et une communauté bienveillante,
        nous célébrons la culture afro-caribéenne dans ce qu'elle a de plus lumineux.
      </p>
      <ul class="wellbeing__list">
        <li>
          <strong>Créativité libérée</strong>
          <span>Pas besoin d'être artiste, juste d'avoir envie.</span>
        </li>
        <li>
          <strong>Bien-être authentique</strong>
          <span>Des pratiques ancrées, pas des tendances vides.</span>
        </li>
        <li>
          <strong>Communauté chaleureuse</strong>
          <span>On vient seule, on repart avec des liens.</span>
        </li>
      </ul>
      <a href={getNavHref('a-propos', base)} class="btn btn--ghost">En savoir plus sur Massoda</a>
    </div>
  </div>
</section>

<style>
  .wellbeing {
    background: var(--color-bg);
  }

  .wellbeing__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  .wellbeing__visual {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .wellbeing__image-frame {
    width: 100%;
    max-width: 400px;
    aspect-ratio: 3 / 4;
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
  }

  .wellbeing__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .wellbeing__accent-dot {
    position: absolute;
    bottom: -16px;
    right: 10%;
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: var(--color-accent);
    opacity: 0.12;
  }

  .wellbeing__content .overline {
    display: block;
    margin-bottom: var(--space-3);
  }

  .wellbeing__content h2 {
    margin-bottom: var(--space-6);
  }

  .wellbeing__text {
    color: var(--color-text-light);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-8);
  }

  .wellbeing__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    margin-bottom: var(--space-8);
  }

  .wellbeing__list li {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding-left: var(--space-5);
    border-left: 3px solid var(--color-accent);
  }

  .wellbeing__list strong {
    font-weight: var(--weight-semibold);
    font-size: var(--text-base);
  }

  .wellbeing__list span {
    font-size: var(--text-sm);
    color: var(--color-text-light);
  }

  @media (min-width: 768px) {
    .wellbeing__inner {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-16);
    }
  }
</style>
