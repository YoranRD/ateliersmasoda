---
const base = import.meta.env.BASE_URL;
---

<section class="hero">
  <div class="hero__accent-line"></div>
  <div class="hero__halo"></div>
  <div class="hero__halo-brand"></div>

  <div class="container hero__inner">
    <div class="hero__content reveal">

      <div class="hero__meta-strip">
        <span class="hero__meta-chip">Ateliers créatifs</span>
        <span class="hero__meta-sep">·</span>
        <span class="hero__meta-chip">Bien-être</span>
        <span class="hero__meta-sep">·</span>
        <span class="hero__meta-chip">Culture afro-caribéenne</span>
      </div>

      <h1 class="hero__title">
        Créer,<br/>
        partager,<br/>
        <em>rayonner<br/>ensemble.</em>
      </h1>

      <p class="subtitle hero__subtitle">
        Des ateliers qui mêlent créativité, bien-être et culture afro-caribéenne.
        Un espace où l'on se retrouve, où l'on crée, où l'on se fait du bien.
      </p>

      <div class="hero__actions">
        <a href="https://www.billetweb.fr/paint-and-jam-with-love" target="_blank" rel="noopener" class="btn btn--primary">
          Réserver un atelier
        </a>
        <a href={`${base}ateliers/`} class="btn btn--outline">
          Découvrir les ateliers
        </a>
      </div>

      <p class="hero__trust-note">
        <span class="hero__trust-star">✦</span>
        Prochaines dates disponibles
      </p>

    </div>

    <div class="hero__visual reveal reveal-delay-2">
      <div class="hero__frame-wrapper">
        <div class="hero__corner hero__corner--tl"></div>
        <div class="hero__corner hero__corner--br"></div>
        <div class="hero__image-frame">
          <div class="hero__image-placeholder">
            <span class="hero__image-icon">✦</span>
            <span class="hero__image-label">Photo atelier</span>
          </div>
        </div>
        <div class="hero__frame-label">
          <span class="hero__frame-label-name">Masoda</span>
          <span class="hero__frame-label-sub">Paris · 2024</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding-block: var(--space-20) var(--space-24);
    background: var(--color-bg);
  }

  /* Top accent stripe */
  .hero__accent-line {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--color-accent) 0%, var(--color-coral) 55%, transparent 100%);
    z-index: 1;
  }

  /* Halos */
  .hero__halo {
    position: absolute;
    top: -180px;
    right: -120px;
    width: 700px;
    height: 700px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 155, 84, 0.18) 0%, transparent 65%);
    pointer-events: none;
  }

  .hero__halo-brand {
    position: absolute;
    bottom: -150px;
    left: -100px;
    width: 480px;
    height: 480px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(68, 82, 199, 0.6) 0%, transparent 70%);
    pointer-events: none;
  }

  /* Layout */
  .hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  /* Meta chip strip */
  .hero__meta-strip {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
  }

  .hero__meta-chip {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-warm);
    padding: var(--space-1) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    background: var(--color-surface-warm);
    white-space: nowrap;
  }

  .hero__meta-sep {
    color: var(--color-border);
    font-size: var(--text-xs);
  }

  /* Title */
  .hero__title {
    font-family: var(--font-heading);
    font-size: clamp(2.75rem, 6vw, 5rem);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    margin-bottom: var(--space-6);
  }

  .hero__title em {
    font-style: italic;
    color: var(--color-brand);
  }

  /* Subtitle */
  .hero__subtitle {
    max-width: 440px;
    margin-bottom: var(--space-8);
  }

  /* Actions */
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-bottom: var(--space-5);
  }

  /* Trust note */
  .hero__trust-note {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wide);
  }

  .hero__trust-star {
    color: var(--color-accent);
    font-size: 10px;
  }

  /* Visual frame */
  .hero__visual {
    display: flex;
    justify-content: center;
  }

  .hero__frame-wrapper {
    position: relative;
    width: 100%;
    max-width: 400px;
  }

  /* Corner decorative marks */
  .hero__corner {
    position: absolute;
    width: 22px;
    height: 22px;
    z-index: 2;
    pointer-events: none;
  }

  .hero__corner--tl {
    top: -6px;
    left: -6px;
    border-top: 2px solid var(--color-accent);
    border-left: 2px solid var(--color-accent);
  }

  .hero__corner--br {
    bottom: 18px;
    right: -6px;
    border-bottom: 2px solid var(--color-accent);
    border-right: 2px solid var(--color-accent);
  }

  /* Image frame */
  .hero__image-frame {
    width: 100%;
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-xl);
    overflow: hidden;
    position: relative;
    background: linear-gradient(150deg, var(--color-surface-warm) 0%, var(--color-bg-warm) 60%, rgba(255, 155, 84, 0.07) 100%);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-lg);
  }

  .hero__image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
  }

  .hero__image-icon {
    font-size: var(--text-4xl);
    color: var(--color-accent);
    opacity: 0.4;
  }

  .hero__image-label {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-weight: var(--weight-medium);
  }

  /* Floating editorial label */
  .hero__frame-label {
    position: absolute;
    bottom: -14px;
    left: var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    padding: var(--space-2) var(--space-5);
    display: flex;
    align-items: center;
    gap: var(--space-3);
    box-shadow: var(--shadow-sm);
  }

  .hero__frame-label-name {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: var(--text-sm);
    color: var(--color-text);
  }

  .hero__frame-label-sub {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wide);
  }

  /* Responsive */
  @media (min-width: 768px) {
    .hero {
      padding-block: var(--space-24) var(--space-32);
    }

    .hero__inner {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-16);
    }
  }

  @media (min-width: 1024px) {
    .hero__inner {
      grid-template-columns: 1.15fr 0.85fr;
    }
  }
</style>
