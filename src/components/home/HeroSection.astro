---
import { getNavHref } from '../../utils/nav';
import { RESERVATION_URL } from '../../utils/links';

const base = import.meta.env.BASE_URL;
const basePath = base.endsWith('/') ? base : `${base}/`;
const heroImage = `${basePath}images/home/hero-atelier-masoda.png`;
---

<section class="hero">
  <div class="hero__halo"></div>
  <div class="container hero__inner">
    <div class="hero__content reveal">
      <span class="overline">Ateliers créatifs · Bien-être · Lifestyle</span>
      <h1 class="heading-1 hero__title">
        Créer, partager,<br/>
        <em>rayonner ensemble.</em>
      </h1>
      <p class="subtitle hero__subtitle">
        Des ateliers qui mêlent créativité, bien-être et culture afro-caribéenne.
        Un espace où l'on se retrouve, où l'on crée, où l'on se fait du bien.
      </p>
      <div class="hero__actions">
        <a href={RESERVATION_URL} target="_blank" rel="noopener" class="btn btn--primary">
          Réserver un atelier
        </a>
        <a href={getNavHref('ateliers', base)} class="btn btn--outline">
          Découvrir les ateliers
        </a>
      </div>
    </div>
    <div class="hero__visual reveal reveal-delay-2">
      <div class="hero__image-frame">
        <img
          src={heroImage}
          alt="Ambiance d'un atelier Masoda — créativité, partage et bien-être"
          class="hero__image"
          width="960"
          height="1200"
          decoding="async"
          fetchpriority="high"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding-block: var(--space-16) var(--space-20);
    background: var(--color-bg);
  }

  .hero__halo {
    position: absolute;
    top: -120px;
    right: -80px;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 155, 84, 0.15) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  .hero__content {
    max-width: 600px;
  }

  .hero__title {
    margin-top: var(--space-4);
    color: var(--color-text);
  }

  .hero__title em {
    font-style: italic;
    color: var(--color-brand);
  }

  .hero__subtitle {
    margin-top: var(--space-6);
    max-width: 480px;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-top: var(--space-8);
  }

  .hero__visual {
    display: flex;
    justify-content: center;
  }

  .hero__image-frame {
    width: 100%;
    max-width: 480px;
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-xl);
    overflow: hidden;
    position: relative;
    background: linear-gradient(135deg, var(--color-surface-warm) 0%, var(--color-bg-warm) 100%);
    border: 1px solid var(--color-border);
  }

  .hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (min-width: 768px) {
    .hero {
      padding-block: var(--space-24) var(--space-32);
    }

    .hero__halo {
      width: 700px;
      height: 700px;
      top: -200px;
      right: -100px;
    }

    .hero__inner {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-16);
    }
  }

  @media (min-width: 1024px) {
    .hero__inner {
      grid-template-columns: 1.1fr 0.9fr;
    }
  }
</style>
