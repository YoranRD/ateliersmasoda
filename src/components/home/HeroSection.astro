---
const base = import.meta.env.BASE_URL;
---

<section class="hero">
  <div class="hero__accent-line"></div>
  <div class="hero__halo"></div>
  <div class="container hero__inner">
    <div class="hero__content reveal">
      <span class="overline">Ateliers créatifs · Bien-être · Lifestyle</span>
      <h1 class="heading-1 hero__title">
        Créer, partager,<br/>
        <em>rayonner ensemble.</em>
      </h1>
      <p class="subtitle hero__subtitle">
        Des ateliers qui mêlent créativité, bien-être et culture afro-caribéenne.
        Un espace où l'on se retrouve, où l'on crée, où l'on se fait du bien.
      </p>
      <div class="hero__actions">
        <a href="https://www.billetweb.fr/paint-and-jam-with-love" target="_blank" rel="noopener" class="btn btn--primary">
          Réserver un atelier
        </a>
        <a href={`${base}ateliers/`} class="btn btn--outline">
          Découvrir les ateliers
        </a>
      </div>
    </div>
    <div class="hero__visual reveal reveal-delay-2">
      <div class="hero__image-frame">
        <div class="hero__image-placeholder">
          <span class="hero__image-icon">✦</span>
          <span class="hero__image-label">Photo atelier</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding-block: var(--space-16) var(--space-20);
    background: var(--color-bg);
  }

  .hero__accent-line {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--color-accent) 0%, var(--color-coral) 55%, transparent 100%);
    z-index: 1;
  }

  .hero__halo {
    position: absolute;
    top: -120px;
    right: -80px;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 155, 84, 0.15) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  .hero__content {
    max-width: 600px;
  }

  .hero__title {
    margin-top: var(--space-4);
    color: var(--color-text);
  }

  .hero__title em {
    font-style: italic;
    color: var(--color-brand);
  }

  .hero__subtitle {
    margin-top: var(--space-6);
    max-width: 480px;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-top: var(--space-8);
  }

  .hero__visual {
    display: flex;
    justify-content: center;
  }

  .hero__image-frame {
    width: 100%;
    max-width: 480px;
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-xl);
    overflow: hidden;
    position: relative;
    background: linear-gradient(135deg, var(--color-surface-warm) 0%, var(--color-bg-warm) 100%);
    border: 1px solid var(--color-border);
  }

  .hero__image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
  }

  .hero__image-icon {
    font-size: var(--text-4xl);
    color: var(--color-accent);
    opacity: 0.5;
  }

  .hero__image-label {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-weight: var(--weight-medium);
  }

  @media (min-width: 768px) {
    .hero {
      padding-block: var(--space-24) var(--space-32);
    }

    .hero__halo {
      width: 700px;
      height: 700px;
      top: -200px;
      right: -100px;
    }

    .hero__inner {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-16);
    }
  }

  @media (min-width: 1024px) {
    .hero__inner {
      grid-template-columns: 1.1fr 0.9fr;
    }
  }
</style>
