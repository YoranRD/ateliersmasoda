---
const base = import.meta.env.BASE_URL;
const basePath = base.endsWith('/') ? base : `${base}/`;
const communityImage = `${basePath}images/home/communaute-masoda.png`;

const socials = [
  { name: 'Instagram', url: 'https://www.instagram.com/lesateliersmassoda/', handle: '@lesateliersmassoda', icon: `${basePath}icons/social/instagram.svg` },
  { name: 'TikTok', url: 'https://www.tiktok.com/@lesateliersmassoda1', handle: '@lesateliersmassoda1', icon: `${basePath}icons/social/tiktok.svg` },
  { name: 'Pinterest', url: 'https://fr.pinterest.com/barbandchill/', handle: 'barbandchill', icon: `${basePath}icons/social/pinterest.svg` },
];
---

<section class="social section">
  <div class="container social__grid">
    <div class="social__visual reveal">
      <div class="social__image-frame">
        <img
          src={communityImage}
          alt="La communauté Massoda — moments de partage et de complicité"
          class="social__image"
          loading="lazy"
          width="800"
          height="1066"
        />
      </div>
    </div>

    <div class="social__inner reveal reveal-delay-1">
      <span class="overline">Communauté</span>
      <h2 class="heading-3">Rejoignez l'univers Massoda</h2>
      <p class="subtitle">Coulisses d'ateliers, inspirations et rendez-vous à venir : suivez-nous et faites partie de la communauté.</p>

      <div class="social__links">
        {socials.map(social => (
          <a href={social.url} target="_blank" rel="noopener" class="social__card" aria-label={`${social.name} — ${social.handle}`}>
            <span class="social__icon">
              <img src={social.icon} alt="" width="24" height="24" loading="lazy" aria-hidden="true" />
            </span>
            <div class="social__info">
              <strong>{social.name}</strong>
              <span>{social.handle}</span>
            </div>
            <span class="social__arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .social {
    background: var(--color-bg-light);
  }

  .social__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  .social__visual {
    display: flex;
    justify-content: center;
  }

  .social__image-frame {
    width: 100%;
    max-width: 420px;
    aspect-ratio: 3 / 4;
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
  }

  .social__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .social__inner {
    max-width: 600px;
  }

  .social__inner .overline {
    display: block;
    margin-bottom: var(--space-3);
  }

  .social__inner h2 {
    margin-bottom: var(--space-4);
  }

  .social__inner .subtitle {
    margin-bottom: var(--space-8);
  }

  @media (min-width: 768px) {
    .social__grid {
      grid-template-columns: 0.9fr 1.1fr;
      gap: var(--space-16);
    }
  }

  .social__links {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    text-align: left;
  }

  .social__card {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    padding: var(--space-5) var(--space-6);
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    transition: all var(--duration-normal) var(--ease-out);
  }

  .social__card:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .social__icon {
    color: var(--color-accent);
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 155, 84, 0.12);
    border-radius: var(--radius-md);
    transition: background var(--duration-normal) var(--ease-out);
  }

  .social__icon img {
    width: 24px;
    height: 24px;
    display: block;
  }

  .social__card:hover .social__icon {
    background: rgba(255, 155, 84, 0.2);
  }

  .social__info {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .social__info strong {
    font-weight: var(--weight-semibold);
    font-size: var(--text-base);
  }

  .social__info span {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .social__arrow {
    font-size: var(--text-xl);
    color: var(--color-text-muted);
    transition: transform var(--duration-fast) var(--ease-out);
  }

  .social__card:hover .social__arrow {
    transform: translateX(4px);
    color: var(--color-accent);
  }
</style>
