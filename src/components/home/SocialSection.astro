---
const socials = [
  {
    name: 'Instagram',
    url: 'https://www.instagram.com/lesateliersmassoda/',
    handle: '@lesateliersmassoda',
    icon: '◉',
    desc: 'Inspirations, ateliers et coulisses',
    colorVar: 'var(--color-accent)',
    colorHex: '#FF9B54',
  },
  {
    name: 'TikTok',
    url: 'https://www.tiktok.com/@lesateliersmassoda1',
    handle: '@lesateliersmassoda1',
    icon: '▶',
    desc: 'Moments de création en vidéo',
    colorVar: 'var(--color-coral)',
    colorHex: '#E58E79',
  },
  {
    name: 'Pinterest',
    url: 'https://fr.pinterest.com/barbandchill/',
    handle: 'barbandchill',
    icon: '◎',
    desc: 'Moodboards &amp; inspirations curatées',
    colorVar: 'var(--color-warm)',
    colorHex: '#9A5E49',
  },
];
---

<section class="social section">
  <div class="container">

    <div class="social__header reveal">
      <span class="overline">Communauté</span>
      <h2 class="heading-2">Suivez l'aventure Masoda</h2>
      <p class="subtitle">Inspirations, coulisses et moments de partage au quotidien.</p>
    </div>

    <div class="social__grid">
      {socials.map((social, i) => (
        <a
          href={social.url}
          target="_blank"
          rel="noopener"
          class={`social__card reveal reveal-delay-${i + 1}`}
        >
          <div class="social__card-top">
            <div class="social__icon-wrap" style={`background: ${social.colorHex}18; color: ${social.colorVar};`}>
              <span class="social__icon">{social.icon}</span>
            </div>
            <span class="social__arrow">→</span>
          </div>
          <div class="social__card-body">
            <strong class="social__name">{social.name}</strong>
            <span class="social__handle">{social.handle}</span>
            <p class="social__desc" set:html={social.desc}></p>
          </div>
          <div class="social__card-bar" style={`background: ${social.colorVar};`}></div>
        </a>
      ))}
    </div>

  </div>
</section>

<style>
  .social {
    background: var(--color-bg-warm);
  }

  /* Header */
  .social__header {
    text-align: center;
    max-width: 540px;
    margin-inline: auto;
    margin-bottom: var(--space-12);
  }

  .social__header .overline {
    display: block;
    margin-bottom: var(--space-3);
  }

  .social__header h2 {
    margin-bottom: var(--space-4);
  }

  /* Grid */
  .social__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    max-width: 960px;
    margin-inline: auto;
  }

  /* Card */
  .social__card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border-radius: var(--radius-xl);
    border: 1px solid var(--color-border);
    overflow: hidden;
    padding: var(--space-8);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    transition: transform var(--duration-normal) var(--ease-out),
                box-shadow var(--duration-normal) var(--ease-out),
                border-color var(--duration-normal) var(--ease-out);
  }

  .social__card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-border);
  }

  .social__card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: var(--space-6);
  }

  .social__icon-wrap {
    width: 56px;
    height: 56px;
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-2xl);
    flex-shrink: 0;
  }

  .social__icon {
    line-height: 1;
  }

  .social__arrow {
    font-size: var(--text-xl);
    color: var(--color-text-muted);
    transition: transform var(--duration-normal) var(--ease-out),
                color var(--duration-normal) var(--ease-out);
  }

  .social__card:hover .social__arrow {
    transform: translate(4px, -4px);
    color: var(--color-accent);
  }

  .social__card-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    flex: 1;
  }

  .social__name {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: var(--text-2xl);
    font-weight: var(--weight-normal);
    color: var(--color-text);
    line-height: 1.15;
    margin-bottom: var(--space-1);
  }

  .social__handle {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-muted);
    margin-bottom: var(--space-3);
  }

  .social__desc {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    line-height: var(--leading-normal);
  }

  /* Color accent bar at bottom — reveals on hover */
  .social__card-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    opacity: 0;
    transition: opacity var(--duration-normal) var(--ease-out);
  }

  .social__card:hover .social__card-bar {
    opacity: 1;
  }

  @media (min-width: 640px) {
    .social__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
