---
const socials = [
  { name: 'Instagram', url: 'https://www.instagram.com/lesateliersmassoda/', handle: '@lesateliersmassoda', icon: '◉' },
  { name: 'TikTok', url: 'https://www.tiktok.com/@lesateliersmassoda1', handle: '@lesateliersmassoda1', icon: '▶' },
  { name: 'Pinterest', url: 'https://fr.pinterest.com/barbandchill/', handle: 'barbandchill', icon: '◎' },
];
---

<section class="social section">
  <div class="container">
    <div class="social__inner reveal">
      <span class="overline">Communauté</span>
      <h2 class="heading-3">Rejoignez l'univers Masoda</h2>
      <p class="subtitle">Inspirations, coulisses et moments de partage au quotidien.</p>

      <div class="social__links">
        {socials.map(social => (
          <a href={social.url} target="_blank" rel="noopener" class="social__card">
            <span class="social__icon">{social.icon}</span>
            <div class="social__info">
              <strong>{social.name}</strong>
              <span>{social.handle}</span>
            </div>
            <span class="social__arrow">→</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .social {
    background: var(--color-bg-light);
  }

  .social__inner {
    text-align: center;
    max-width: 600px;
    margin-inline: auto;
  }

  .social__inner .overline {
    display: block;
    margin-bottom: var(--space-3);
  }

  .social__inner h2 {
    margin-bottom: var(--space-4);
  }

  .social__inner .subtitle {
    margin-bottom: var(--space-10);
  }

  .social__links {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    text-align: left;
  }

  .social__card {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    padding: var(--space-5) var(--space-6);
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    transition: all var(--duration-normal) var(--ease-out);
  }

  .social__card:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .social__icon {
    font-size: var(--text-2xl);
    color: var(--color-accent);
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 155, 84, 0.1);
    border-radius: var(--radius-md);
  }

  .social__info {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .social__info strong {
    font-weight: var(--weight-semibold);
    font-size: var(--text-base);
  }

  .social__info span {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .social__arrow {
    font-size: var(--text-xl);
    color: var(--color-text-muted);
    transition: transform var(--duration-fast) var(--ease-out);
  }

  .social__card:hover .social__arrow {
    transform: translateX(4px);
    color: var(--color-accent);
  }
</style>
