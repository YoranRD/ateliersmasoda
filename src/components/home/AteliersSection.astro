---
import { getNavHref } from '../../utils/nav';

const base = import.meta.env.BASE_URL;

const ateliers = [
  {
    tag: 'Créativité',
    num: '01',
    title: 'Paint & Jam',
    description: 'Peinture intuitive sur fond de musique, dans une ambiance conviviale et libératrice.',
    accent: 'var(--color-accent)',
    hex: '#FF9B54',
    featured: true,
  },
  {
    tag: 'Bien-être',
    num: '02',
    title: 'Self-Care Rituals',
    description: 'Rituels de soin inspirés des traditions afro-caribéennes, pour un moment de douceur.',
    accent: 'var(--color-coral)',
    hex: '#E58E79',
    featured: false,
  },
  {
    tag: 'Communauté',
    num: '03',
    title: 'Ateliers sur mesure',
    description: 'Événements privés, team building ou anniversaires : une expérience Masoda à votre image.',
    accent: 'var(--color-brand)',
    hex: '#4452C7',
    featured: false,
  },
];

const featured = ateliers[0];
const secondary = ateliers.slice(1);
---

<section class="ateliers-section section" id="ateliers">
  <div class="container">

    <div class="ateliers-section__header reveal">
      <div>
        <span class="overline">Nos ateliers</span>
        <h2 class="heading-2">Des expériences qui font du bien</h2>
      </div>
      <p class="subtitle ateliers-section__subtitle">
        Chaque atelier est un moment de partage, de création et de reconnexion à soi.
      </p>
    </div>

    <!-- Featured atelier — full-width editorial card -->
    <article class="atelier-featured reveal">
      <div class="atelier-featured__image" style={`background: linear-gradient(150deg, ${featured.hex}1A 0%, ${featured.hex}06 100%);`}>
        <span class="atelier-featured__icon" style={`color: ${featured.accent};`}>✦</span>
        <div class="atelier-featured__image-tag" style={`color: ${featured.accent};`}>{featured.tag}</div>
      </div>
      <div class="atelier-featured__body">
        <div class="atelier-featured__meta">
          <span class="atelier-featured__num">{featured.num}</span>
          <span class="atelier-featured__badge" style={`background: ${featured.hex}18; color: ${featured.accent};`}>
            À la une
          </span>
        </div>
        <h3 class="atelier-featured__title">{featured.title}</h3>
        <p class="atelier-featured__desc">{featured.description}</p>
        <div class="atelier-featured__actions">
          <a href="https://www.billetweb.fr/paint-and-jam-with-love" target="_blank" rel="noopener" class="btn btn--primary">
            Réserver ma place
          </a>
        </div>
      </div>
    </article>

    <!-- Secondary ateliers -->
    <div class="ateliers-secondary">
      {secondary.map((atelier, i) => (
        <article class={`atelier-card reveal reveal-delay-${i + 1}`}>
          <div class="atelier-card__image" style={`background: linear-gradient(150deg, ${atelier.hex}16 0%, ${atelier.hex}05 100%);`}>
            <span class="atelier-card__icon" style={`color: ${atelier.accent};`}>✦</span>
          </div>
          <div class="atelier-card__body">
            <div class="atelier-card__meta">
              <span class="atelier-card__num">{atelier.num}</span>
              <span class="atelier-card__tag" style={`color: ${atelier.accent};`}>{atelier.tag}</span>
            </div>
            <h3 class="atelier-card__title">{atelier.title}</h3>
            <p class="atelier-card__desc">{atelier.description}</p>
          </div>
          <div class="atelier-card__footer" style={`border-top-color: ${atelier.hex}25;`}>
            <a href={getNavHref('ateliers', base)} class="btn btn--ghost">Découvrir</a>
          </div>
          <div class="atelier-card__accent-bar" style={`background: ${atelier.accent};`}></div>
        </article>
      ))}
    </div>

    <div class="ateliers-section__footer reveal">
      <a href={getNavHref('ateliers', base)} class="btn btn--ghost">
        Voir tous les ateliers
      </a>
    </div>

  </div>
</section>

<style>
  .ateliers-section {
    background: var(--color-bg-warm);
  }

  /* Section header */
  .ateliers-section__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    margin-bottom: var(--space-12);
  }

  .ateliers-section__header .overline {
    display: block;
    margin-bottom: var(--space-3);
  }

  .ateliers-section__header h2 {
    margin-top: var(--space-2);
  }

  .ateliers-section__subtitle {
    max-width: 420px;
  }

  /* ── Featured card ── */
  .atelier-featured {
    display: grid;
    grid-template-columns: 1fr;
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-md);
    margin-bottom: var(--space-8);
    transition: box-shadow var(--duration-normal) var(--ease-out),
                transform var(--duration-normal) var(--ease-out);
  }

  .atelier-featured:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-3px);
  }

  .atelier-featured__image {
    position: relative;
    aspect-ratio: 16 / 7;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .atelier-featured__icon {
    font-size: 3.5rem;
    opacity: 0.45;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .atelier-featured:hover .atelier-featured__icon {
    transform: scale(1.08) rotate(8deg);
  }

  .atelier-featured__image-tag {
    position: absolute;
    top: var(--space-5);
    left: var(--space-5);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    background: var(--color-surface);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border);
  }

  .atelier-featured__body {
    padding: var(--space-8);
  }

  .atelier-featured__meta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
  }

  .atelier-featured__num {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: var(--text-3xl);
    color: var(--color-text-muted);
    line-height: 1;
    opacity: 0.45;
  }

  .atelier-featured__badge {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
  }

  .atelier-featured__title {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-2xl), 3vw, var(--text-4xl));
    line-height: var(--leading-tight);
    margin-bottom: var(--space-4);
    color: var(--color-text);
  }

  .atelier-featured__desc {
    font-size: var(--text-base);
    color: var(--color-text-light);
    line-height: var(--leading-normal);
    max-width: 500px;
    margin-bottom: var(--space-8);
  }

  /* ── Secondary cards ── */
  .ateliers-secondary {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    margin-bottom: var(--space-4);
  }

  .atelier-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
    transition: transform var(--duration-normal) var(--ease-out),
                box-shadow var(--duration-normal) var(--ease-out);
  }

  .atelier-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lg);
  }

  .atelier-card__image {
    position: relative;
    aspect-ratio: 4 / 3;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .atelier-card__icon {
    font-size: var(--text-3xl);
    opacity: 0.45;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .atelier-card:hover .atelier-card__icon {
    transform: scale(1.1) rotate(6deg);
  }

  .atelier-card__body {
    padding: var(--space-6);
    flex: 1;
  }

  .atelier-card__meta {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
  }

  .atelier-card__num {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: var(--text-2xl);
    color: var(--color-text-muted);
    line-height: 1;
    opacity: 0.4;
  }

  .atelier-card__tag {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
  }

  .atelier-card__title {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    line-height: var(--leading-snug);
    margin-bottom: var(--space-3);
    color: var(--color-text);
  }

  .atelier-card__desc {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    line-height: var(--leading-normal);
  }

  .atelier-card__footer {
    padding: var(--space-4) var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  /* Bottom accent bar — appears on hover */
  .atelier-card__accent-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    opacity: 0;
    transition: opacity var(--duration-normal) var(--ease-out);
  }

  .atelier-card:hover .atelier-card__accent-bar {
    opacity: 1;
  }

  /* Footer CTA */
  .ateliers-section__footer {
    text-align: center;
    margin-top: var(--space-8);
  }

  /* Responsive */
  @media (min-width: 640px) {
    .ateliers-secondary {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 768px) {
    .ateliers-section__header {
      flex-direction: row;
      align-items: flex-start;
      justify-content: space-between;
    }

    .atelier-featured {
      grid-template-columns: 1fr 1fr;
    }

    .atelier-featured__image {
      aspect-ratio: auto;
      min-height: 320px;
    }
  }
</style>
