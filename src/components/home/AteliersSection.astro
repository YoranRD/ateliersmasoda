---
import { getNavHref } from '../../utils/nav';
import { RESERVATION_URL } from '../../utils/links';

const base = import.meta.env.BASE_URL;
const basePath = base.endsWith('/') ? base : `${base}/`;

const ateliers = [
  {
    tag: 'Artisanat',
    title: 'Baya',
    description: 'Création de perles de taille, portées pour la féminité, l\'ancrage et la confiance en soi.',
    accent: 'var(--color-brand)',
    image: `${basePath}images/home/atelier-baya.png`,
    alt: 'Atelier Baya — perles traditionnelles de Masoda',
  },
  {
    tag: 'Créativité',
    title: 'Paint & Jam',
    description: 'Peinture intuitive sur des sons afro, soul et jazz, dans une ambiance conviviale et libératrice.',
    accent: 'var(--color-accent)',
    image: `${basePath}images/home/atelier-paint-jam.png`,
    alt: 'Atelier Paint & Jam — peinture intuitive en musique',
  },
  {
    tag: 'Bien-être',
    title: 'Afro-diététique & plantes',
    description: 'Plantes africaines, tisanes et rituels doux pour renouer avec une nutrition ancrée et ancestrale.',
    accent: 'var(--color-coral)',
    image: `${basePath}images/home/bien-etre-lifestyle.png`,
    alt: 'Atelier afro-diététique — plantes africaines, tisanes et bien-être',
  },
];
---

<section class="ateliers-section section" id="ateliers">
  <div class="container">
    <div class="ateliers-section__header reveal">
      <span class="overline">Nos ateliers</span>
      <h2 class="heading-2">Trois expériences pour se retrouver</h2>
      <p class="subtitle">Trois univers — artisanat, créativité, bien-être — pensés comme des moments de partage et de reconnexion à soi.</p>
    </div>

    <div class="ateliers-section__grid">
      {ateliers.map((atelier, i) => (
        <article class={`card reveal reveal-delay-${i + 1}`}>
          <div class="ateliers-section__image-wrap" style={`background: linear-gradient(135deg, ${atelier.accent}22, ${atelier.accent}08);`}>
            <img
              src={atelier.image}
              alt={atelier.alt}
              class="ateliers-section__image"
              loading="lazy"
              width="800"
              height="600"
            />
          </div>
          <div class="card__body">
            <span class="card__tag" style={`color: ${atelier.accent};`}>{atelier.tag}</span>
            <h3 class="card__title">{atelier.title}</h3>
            <p class="card__text">{atelier.description}</p>
          </div>
        </article>
      ))}
    </div>

    <div class="ateliers-section__cta reveal">
      <a href={RESERVATION_URL} target="_blank" rel="noopener" class="btn btn--primary">
        Réserver un atelier
      </a>
      <a href={getNavHref('ateliers', base)} class="btn btn--ghost">
        Voir tous les ateliers
      </a>
    </div>
  </div>
</section>

<style>
  .ateliers-section {
    background: var(--color-bg-light);
  }

  .ateliers-section__header {
    text-align: center;
    max-width: 600px;
    margin-inline: auto;
    margin-bottom: var(--space-12);
  }

  .ateliers-section__header .overline {
    margin-bottom: var(--space-3);
    display: block;
  }

  .ateliers-section__header h2 {
    margin-top: var(--space-3);
  }

  .ateliers-section__header .subtitle {
    margin-top: var(--space-4);
  }

  .ateliers-section__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  .ateliers-section__image-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .ateliers-section__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .card:hover .ateliers-section__image {
    transform: scale(1.03);
  }

  .ateliers-section__cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--space-6);
    margin-top: var(--space-12);
  }

  @media (min-width: 768px) {
    .ateliers-section__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
