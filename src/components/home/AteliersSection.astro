---
const base = import.meta.env.BASE_URL;

const ateliers = [
  {
    tag: 'Créativité',
    title: 'Paint & Jam',
    description: 'Peinture intuitive sur fond de musique, dans une ambiance conviviale et libératrice.',
    accent: 'var(--color-accent)',
  },
  {
    tag: 'Bien-être',
    title: 'Self-Care Rituals',
    description: 'Rituels de soin inspirés des traditions afro-caribéennes, pour un moment de douceur.',
    accent: 'var(--color-coral)',
  },
  {
    tag: 'Communauté',
    title: 'Ateliers sur mesure',
    description: 'Événements privés, team building ou anniversaires : une expérience Masoda à votre image.',
    accent: 'var(--color-brand)',
  },
];
---

<section class="ateliers-section section" id="ateliers">
  <div class="container">
    <div class="ateliers-section__header reveal">
      <span class="overline">Nos ateliers</span>
      <h2 class="heading-2">Des expériences qui font du bien</h2>
      <p class="subtitle">Chaque atelier est un moment de partage, de création et de reconnexion à soi.</p>
    </div>

    <div class="ateliers-section__grid">
      {ateliers.map((atelier, i) => (
        <article class={`card reveal reveal-delay-${i + 1}`}>
          <div class="card__image" style={`background: linear-gradient(135deg, ${atelier.accent}22, ${atelier.accent}08);`}>
            <span class="ateliers-section__icon" style={`color: ${atelier.accent};`}>✦</span>
          </div>
          <div class="card__body">
            <span class="card__tag" style={`color: ${atelier.accent};`}>{atelier.tag}</span>
            <h3 class="card__title">{atelier.title}</h3>
            <p class="card__text">{atelier.description}</p>
          </div>
        </article>
      ))}
    </div>

    <div class="ateliers-section__cta reveal">
      <a href="https://www.billetweb.fr/paint-and-jam-with-love" target="_blank" rel="noopener" class="btn btn--primary">
        Réserver un atelier
      </a>
      <a href={`${base}ateliers/`} class="btn btn--ghost">
        Voir tous les ateliers
      </a>
    </div>
  </div>
</section>

<style>
  .ateliers-section {
    background: var(--color-bg-light);
  }

  .ateliers-section__header {
    text-align: center;
    max-width: 600px;
    margin-inline: auto;
    margin-bottom: var(--space-12);
  }

  .ateliers-section__header .overline {
    margin-bottom: var(--space-3);
    display: block;
  }

  .ateliers-section__header h2 {
    margin-top: var(--space-3);
  }

  .ateliers-section__header .subtitle {
    margin-top: var(--space-4);
  }

  .ateliers-section__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  .ateliers-section__icon {
    font-size: var(--text-4xl);
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .card__image {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ateliers-section__cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--space-6);
    margin-top: var(--space-12);
  }

  @media (min-width: 768px) {
    .ateliers-section__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
